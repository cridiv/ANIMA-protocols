# ANIMA Agent Runtime - Environment Configuration Template
# Copy this file to .env and fill in your values

# Price Data Feed Configuration
PRICE_FEED_SOURCE=coingecko
PRICE_POLL_INTERVAL=30

# Sui Network Configuration
SUI_NETWORK=testnet
SUI_RPC_URL=https://testnet-rpc.sui.io
SUI_PACKAGE_ID=

# Walrus Configuration
WALRUS_ENDPOINT=https://walrus-testnet.sui.io
WALRUS_NETWORK=testnet

# Agent Configuration
AGENT_ID=
AGENT_PRIVATE_KEY=
AGENT_NAME=ANIMA-Agent-1

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json

# Backend API Configuration
BACKEND_API_URL=http://localhost:3000
BACKEND_API_TIMEOUT=30

# Feature Flags
ENABLE_PRICE_MONITOR=true
ENABLE_WALRUS_INTEGRATION=true
ENABLE_BACKEND_EXECUTION=false
